     XPath sobre web.login_layout (rama 19.0). Verificado contra:
     https://github.com/odoo/odoo/blob/19.0/addons/web/views/webclient_templates.xml
     línea 128: <a href="https://www.odoo.com?utm_source=db..."> Powered by <span>Odoo</span></a>
-->
<odoo>

    <template id="login_layout_debrand"
              inherit_id="web.login_layout"
              name="Trixocom Debrand: Login Layout">
        <xpath expr="//a[contains(@href, 'odoo.com') and contains(@href, 'utm_medium=auth')]"
               position="replace">
            <t t-set="_tx_name"
               t-value="request.env['ir.config_parameter'].sudo().get_param('trixocom_debrand.brand_name') or 'Trixocom ERP'"/>
            <t t-set="_tx_url"
               t-value="request.env['ir.config_parameter'].sudo().get_param('trixocom_debrand.brand_url') or 'https://www.trixocom.com'"/>
            <a t-att-href="_tx_url" target="_blank">Powered by <span t-out="_tx_name"/></a>
        </xpath>
    </template>

</odoo>
