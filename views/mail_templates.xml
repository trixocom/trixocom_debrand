     Inherits sobre mail/data/mail_templates_email_layouts.xml (rama 19.0).
     Verificado contra:
     https://github.com/odoo/odoo/blob/19.0/addons/mail/data/mail_templates_email_layouts.xml
     - mail.mail_notification_layout: línea 86, footer "Powered by Odoo"
     - mail.mail_notification_light:  línea 160, footer "Powered by Odoo"

     IMPORTANTE: mail.template renderiza estos layouts con un contexto QWeb que
     NO incluye 'env' como variable global (a diferencia de los templates HTTP
     que tienen request.env). Por eso accedemos via 'company.env', porque
     'company' es un recordset disponible en el contexto del mail layout y
     todo recordset expone .env. Caso real: KeyError 'env' al renderizar
     mail.mail_notification_layout_with_responsible_signature desde un POS sync.
-->
<odoo>
    <data>

        <template id="mail_notification_layout_debrand"
                  inherit_id="mail.mail_notification_layout"
                  name="Trixocom Debrand: Mail Notification Layout">
            <xpath expr="//a[contains(@href, 'odoo.com') and contains(@href, 'utm_medium=email')]"
                   position="replace">
                <t t-set="_tx_name"
                   t-value="(company.env['ir.config_parameter'].sudo().get_param('trixocom_debrand.brand_name') if company else None) or 'Trixocom ERP'"/>
                <t t-set="_tx_url"
                   t-value="(company.env['ir.config_parameter'].sudo().get_param('trixocom_debrand.brand_url') if company else None) or 'https://www.trixocom.com'"/>
                <a target="_blank"
                   t-att-href="_tx_url"
                   t-att-style="'color: ' + (company.email_secondary_color or '#875A7B') + ';'"
                   t-out="_tx_name"/>
            </xpath>
        </template>

        <template id="mail_notification_light_debrand"
                  inherit_id="mail.mail_notification_light"
                  name="Trixocom Debrand: Mail Notification Light">
            <xpath expr="//a[contains(@href, 'odoo.com') and contains(@href, 'utm_medium=email')]"
                   position="replace">
                <t t-set="_tx_name"
                   t-value="(company.env['ir.config_parameter'].sudo().get_param('trixocom_debrand.brand_name') if company else None) or 'Trixocom ERP'"/>
                <t t-set="_tx_url"
                   t-value="(company.env['ir.config_parameter'].sudo().get_param('trixocom_debrand.brand_url') if company else None) or 'https://www.trixocom.com'"/>
                <a target="_blank"
                   t-att-href="_tx_url"
                   t-att-style="'color: ' + (company.email_secondary_color or '#875A7B') + ';'"
                   t-out="_tx_name"/>
            </xpath>
        </template>

    </data>
</odoo>
