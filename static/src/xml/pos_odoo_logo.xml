<?xml version="1.0" encoding="UTF-8"?>
<!-- Copyright 2026 Trixocom
     License LGPL-3.0 or later (https://www.gnu.org/licenses/lgpl-3.0.html).

     Reemplaza el SVG del logo Odoo dentro del POS por el logo de la compañía.
     URL estándar /web/binary/company_logo apunta a res.company.logo de la
     compañía actual del usuario. Si el cliente no subió logo, Odoo devuelve un
     placeholder gris.

     Componente original:
     addons/point_of_sale/static/src/app/components/odoo_logo/odoo_logo.xml
     Usado por: customer_display.xml (Powered by [logo]) y otros lugares.
-->
<templates xml:space="preserve">

    <t t-inherit="point_of_sale.OdooLogo"
       t-inherit-mode="extension">
        <xpath expr="//svg" position="replace">
            <img class="img-fluid o_tx_pos_company_logo"
                 src="/web/binary/company_logo"
                 alt="Company Logo"
                 t-attf-style="{{ props.style }}; max-height: 2.2rem; object-fit: contain;"/>
        </xpath>
    </t>

</templates>
