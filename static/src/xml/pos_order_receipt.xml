<?xml version="1.0" encoding="UTF-8"?>
<!-- Copyright 2026 Trixocom
     License LGPL-3.0 or later (https://www.gnu.org/licenses/lgpl-3.0.html).

     Reemplaza el footer 'Powered by <b> Odoo </b>' del ticket POS por
     'Powered by <b>{brand_name}</b>'. El getter trixocomBrand viene del
     patch en pos_order_receipt.js.

     Template original:
     addons/point_of_sale/static/src/app/screens/receipt_screen/receipt/order_receipt.xml
     línea 147: <span>Powered by <b> Odoo </b></span>
     wrapper: <div class="pos-receipt-order-data text-center pt-3">
-->
<templates xml:space="preserve">

    <t t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt-order-data')]" position="replace">
            <div class="pos-receipt-order-data text-center pt-3">
                <span>Powered by <b t-out="trixocomBrand"/></span>
            </div>
        </xpath>
    </t>

</templates>
