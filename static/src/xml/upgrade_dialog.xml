<!-- Copyright 2026 Trixocom
     License LGPL-3.0 or later (https://www.gnu.org/licenses/lgpl-3.0.html).

     Inherit (extension) sobre web.UpgradeDialog, definido en:
     addons/web/static/src/webclient/settings_form_view/fields/upgrade_dialog.xml
     (rama 19.0).

     Saca todas las referencias a 'Odoo Enterprise' y al iframe de YouTube.
     El texto queda neutral y configurable a nivel servidor vía
     ir.config_parameter trixocom_debrand.brand_name no se inyecta acá porque
     el template OWL del Dialog se renderiza sin acceso directo a session_info;
     para reemplazos dinámicos hay que patchear el componente UpgradeDialog, lo
     cual queda fuera del alcance de v1 (sólo lo neutralizamos).
-->
<templates xml:space="preserve">

    <t t-name="trixocom_debrand.UpgradeDialog"
       t-inherit="web.UpgradeDialog"
       t-inherit-mode="extension"
       owl="1">
        <xpath expr="//Dialog" position="attributes">
            <attribute name="title.translate">Premium feature</attribute>
        </xpath>
        <xpath expr="//div[@role='status']/div[1]" position="replace">
            <div class="w-100">
                <p>
                    This feature is part of the premium edition.
                </p>
                <p>
                    Please contact your administrator for more information.
                </p>
            </div>
        </xpath>
        <xpath expr="//div[hasclass('o_video_embed')]" position="replace">
            <!-- Video embed removed by Trixocom Debrand. -->
        </xpath>
    </t>

</templates>
